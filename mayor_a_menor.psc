Algoritmo mayor_a_menor
	definir nombre como cadena 
	definir edad como entero 
	
	Escribir "ingrese nombre"
	leer nombre
	Escribir "ingrese edad"
	leer edad 
	
	si edad>=18 Entonces
		Escribir nombre " tiene ",edad," aþos y es mayor de edad"
	SiNo
		Escribir nombre " tiene ",edad,"aþos y es menor de edad"
	FinSi
	
	
FinAlgoritmo
