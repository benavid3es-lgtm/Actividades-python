Algoritmo reloj_digital
	
    Para hora <- 0 Hasta 23 Hacer
        Para minuto <- 0 Hasta 59 Hacer
            Para segundo <- 0 Hasta 59 Hacer
				
                Limpiar Pantalla
                Escribir hora, " : ", minuto, " : ", segundo
				
                Esperar 1 Segundos   // Para que avance como reloj normal
				
            FinPara
        FinPara
    FinPara
	
FinAlgoritmo
